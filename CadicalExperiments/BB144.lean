@[simp]
def any_loc_is_aux (locs : Fin 11 → BitVec 8) (i : ℕ) (j : ℕ) :=
  match j with
  | 0 => locs 0 = i
  | j₀ + 1 => (locs (Fin.ofNat 11 j) = i) ∨ any_loc_is_aux locs i j₀

@[simp]
def any_loc_is (locs : Fin 11 → BitVec 8) (i : ℕ) :=
  any_loc_is_aux locs i 10

def loc_constraints_ith
  (locs : Fin 11 → BitVec 8)
  (errs : BitVec 144)
  (i : ℕ) :=
  errs[i]! = any_loc_is locs i
